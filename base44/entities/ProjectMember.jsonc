{
  "name": "ProjectMember",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string"
    },
    "user_email": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "team_member",
        "client"
      ],
      "default": "team_member"
    }
  },
  "required": [
    "project_id",
    "user_email",
    "role"
  ]
}